import numpy as np

class GDRegressor:
  def __init__(self, learning_rate=0.01, epochs=100):
    self.learning_rate = learning_rate
    self.epochs = epochs
    self.intercept_ = 0
    self.coef_ = None
    
  def fit(self, X_train, y_train):
    n_samples, n_features = X_train.shape
    
    # Sabhi features ke liye slope (weights) ko 1 se initialize kiya (jaisa aapne kiya tha)
    self.coef_ = np.ones(n_features)

    for i in range(self.epochs):
       # 1. Prediction nikalna (Shape: n_samples,)
       yhat = self.intercept_ + np.dot(X_train, self.coef_)    
       
       # 2. Intercept ka slope (Purana formula)
       intercept_slope = -2 * np.sum(y_train - yhat) / n_samples
       
       # 3. Coef ka slope (Sahi Matrix multiplication bina faltu np.sum ke)
       # X_train.T ka shape (n_features, n_samples) hota hai
       coef_slope = -2 * np.dot(X_train.T, (y_train - yhat)) / n_samples
       
       # 4. Parameters update karna
       self.intercept_ = self.intercept_ - (self.learning_rate * intercept_slope)
       self.coef_ = self.coef_ - (self.learning_rate * coef_slope)

  def predict(self, X_test):
    # Sahi order: Pehle X_test matrix, fir coef_ vector
    return np.dot(X_test, self.coef_) + self.intercept_
